public class InventoryStockChecker {
    public static void main(String[] args) {

        int stock[] = {20, 5, 15, 3, 8};
        int R = 10;

        int count = 0;

        for (int i = 0; i < stock.length; i++) {
            if (stock[i] < R) {
                count++;
            }
        }

        System.out.println(count);
    }
}
