public class StudentGradeEvaluation {

    public static void main(String[] args) {

        int marks[] = {80, 85, 90, 75, 70};

        int total = 0;

        for (int i = 0; i < marks.length; i++) {
            total += marks[i];
        }

        int percentage = total / marks.length;  // integer percentage

        char grade;

        if (percentage >= 90) {
            grade = 'A';
        } else if (percentage >= 75) {
            grade = 'B';
        } else if (percentage >= 60) {
            grade = 'C';
        } else {
            grade = 'F';
        }

        System.out.println(total + " " + percentage + " " + grade);
    }
}
